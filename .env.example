# Use mock reservations instead of Lodgify
NEXT_PUBLIC_USE_MOCK_DATA=true

# Optional: use Lodgify Reservations API instead of iCal (set lodgifyPropertyId per unit in config)
# LODGIFY_API_KEY=your_api_key_from_lodgify

# Optional server-only equivalent (if you prefer not to expose the public flag)
# USE_MOCK_DATA=true
